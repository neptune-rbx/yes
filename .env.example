# ═══════════════════════════════════════════════════════════
# East Coaster Tracker - Environment Configuration
# 
# Copy this file to .env.local and update the values
# ═══════════════════════════════════════════════════════════

# API Base URL - Where your Cloudflare Worker is deployed
# Examples:
#   Production (External Worker): https://east-coaster.your-domain.workers.dev
#   Development (Local Worker):   http://localhost:8787
#   Relative Path (Same Origin):  /api
#
# Default: /api (relative path - useful if frontend & worker on same domain)

VITE_API_BASE=/api
